---
/**
 * Layout.astro — échafaudage de page réutilisé par TOUS les sites.
 *
 * Structure : slot "header" → <slot/> (body : hero + sections) → slot "footer".
 * La nav ET le footer viennent de la BIBLIOTHÈQUE (sections navbars / pieds-de-page),
 * intégrés par projet et placés dans les slots nommés — le layout ne code aucune
 * nav/footer en dur (variété par projet). Voir SKILL.md §4.
 *
 * TOKENS : le layout n'écrit jamais une couleur en dur — il utilise des
 * variables CSS (var(--x)) avec des défauts neutres, surchargées par le
 * theme.css du site (généré depuis blueprint.json > charte.tokens). Voir SKILL.md.
 *
 * Langue : FR uniquement pour l'instant.
 */
export interface Props {
  title: string;
  description?: string;
  lang?: string;
}
const { title, description = "", lang = "fr" } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <!-- Tokens de charte du site (surcharge les défauts neutres du Layout) -->
    <link rel="stylesheet" href="/theme.css" />
  </head>

  <body>
    <a class="skip-link" href="#contenu">Aller au contenu</a>
    <slot name="header" />
    <main id="contenu">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>

<style is:global>
  /* ======================================================================
     1. TOKENS — valeurs PAR DÉFAUT (neutres). Surchargées par le theme.css
        du site (mêmes noms que blueprint.json > charte.tokens).
     ====================================================================== */
  :root {
    --bg: #ffffff;
    --surface: #f5f6f7;
    --fg: #111111;
    --muted: #5a625b;
    --line: #e4e7e5;
    --accent: #111111;          /* défaut NEUTRE — surchargé par le theme.css du site */
    --accent-contrast: #ffffff; /* texte lisible SUR l'accent */
    --accent-dark: color-mix(in srgb, var(--accent) 85%, #000);      /* survols */
    --accent-soft: color-mix(in srgb, var(--accent) 14%, transparent); /* teintes / halos */
    --shadow-color: color-mix(in srgb, var(--fg) 38%, transparent);     /* ombres portées */

    --font: system-ui, -apple-system, "Segoe UI", Roboto, Inter, sans-serif;
    --font-heading: var(--font);

    --radius: 0;                /* arrondis désactivés pour l'instant */

    /* Échelle typographique fluide (clamp : mobile → desktop) */
    --step--1: clamp(0.92rem, 0.88rem + 0.20vw, 1.00rem);
    --step-0:  1.2rem;          /* corps = 1.2rem */
    --step-1:  clamp(1.20rem, 1.10rem + 0.50vw, 1.50rem);
    --step-2:  clamp(1.44rem, 1.28rem + 0.80vw, 2.00rem);
    --step-3:  clamp(1.73rem, 1.48rem + 1.24vw, 2.67rem);
    --step-4:  clamp(2.07rem, 1.70rem + 1.86vw, 3.55rem);

    /* Échelle d'espacement */
    --space-2xs: 0.5rem;
    --space-xs:  0.75rem;
    --space-s:   1rem;
    --space-m:   1.5rem;
    --space-l:   2.5rem;
    --space-xl:  4rem;
    --space-2xl: 6rem;

    /* Conteneur & rythme de section */
    --container: 1200px;
    --gutter: clamp(1rem, 5vw, 2rem);
    --section-y: clamp(3rem, 6vw, var(--space-2xl));

    --line-height: 1.6;
    --line-height-heading: 1.15;
  }

  /* ======================================================================
     2. RESET minimal
     ====================================================================== */
  *, *::before, *::after { box-sizing: border-box; }
  * { margin: 0; }
  html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }
  body {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
    color: var(--fg);
    font-family: var(--font);
    font-size: var(--step-0);
    line-height: var(--line-height);
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
  main { flex: 1 0 auto; }
  img, picture, svg, video, canvas { display: block; max-width: 100%; height: auto; }
  input, button, textarea, select { font: inherit; color: inherit; }
  p, li { text-wrap: pretty; }

  /* ======================================================================
     3. TYPOGRAPHIE de base
     ====================================================================== */
  h1, h2, h3, h4 {
    font-family: var(--font-heading);
    line-height: var(--line-height-heading);
    text-wrap: balance;
    font-weight: 700;
  }
  h1 { font-size: var(--step-4); }
  h2 { font-size: var(--step-3); }
  h3 { font-size: var(--step-2); }
  h4 { font-size: var(--step-1); }
  small { font-size: var(--step--1); }

  a { color: inherit; text-decoration-color: color-mix(in srgb, currentColor 40%, transparent); }
  a:hover { text-decoration-color: currentColor; }

  /* ======================================================================
     4. RYTHME & CONTENEUR (helpers réutilisables par les sections)
     ====================================================================== */
  .container {
    width: 100%;
    max-width: var(--container);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }
  /* Rythme vertical UNIFORME : toute section ajoutée hérite du même padding.
     Les sections normalisées ne portent plus de padding vertical interne. */
  main > section { padding-block: var(--section-y); }
  /* Exception « bleed » : sections plein écran / pleine largeur qui gèrent
     leur propre hauteur (héros 100dvh, bandes) → pas de padding imposé. */
  main > section[data-bleed] { padding-block: 0; }

  /* Bouton de base (réutilisable) */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5em;
    min-height: 44px;
    padding: 0.7em 1.4em;
    border: 1px solid transparent;
    border-radius: var(--radius);
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.12s ease, background 0.15s ease, border-color 0.15s ease;
  }
  .btn:active { transform: translateY(1px); }
  .btn--primary { background: var(--accent); color: var(--accent-contrast); }
  .btn--primary:hover { background: var(--accent-dark); }
  .btn--ghost { background: transparent; color: var(--fg); border-color: var(--line); }
  .btn--ghost:hover { border-color: var(--fg); }

  /* ======================================================================
     5. ACCESSIBILITÉ
     ====================================================================== */
  :where(a, button, input, textarea, select, [tabindex]):focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
  }
  .skip-link {
    position: absolute;
    left: var(--space-s);
    top: -4rem;
    z-index: 1000;
    background: var(--accent);
    color: var(--accent-contrast);
    padding: var(--space-2xs) var(--space-s);
    border-radius: var(--radius);
    transition: top 0.15s ease;
  }
  .skip-link:focus { top: var(--space-s); }

  /* ======================================================================
     6. MOBILE — le texte du contenu se centre (règle de base, héritée par
        toutes les sections via la cascade de text-align).
     ====================================================================== */
  @media (max-width: 640px) {
    main { text-align: center; }
    /* recentre aussi les rangées de boutons/listes en flex qui, sinon,
       ignorent text-align (positionnées par justify-content). */
    main :where(.hero__cta, .btn) { justify-content: center; }
  }

  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    *, *::before, *::after {
      animation-duration: 0.001ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.001ms !important;
    }
  }
</style>
