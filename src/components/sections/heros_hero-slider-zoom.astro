---
/**
 * Intégration — section `heros_hero-slider-zoom` (hero PLEIN ÉCRAN, data-bleed).
 * Règles Phase 2 appliquées :
 *   1. `:root` local, reset et styles body supprimés → tokens hérités de la base.
 *   2. Import Google Fonts supprimé (la base fournit --font).
 *   3. Vrai hero fullscreen → 100dvh CONSERVÉ + attribut `data-bleed` sur la section.
 *   4. Couleurs codées en dur (#0b0b0d, #fff, rgba blancs) → tokens
 *      (--bg, --fg, --accent, --accent-2, --accent-contrast, color-mix).
 *   5. Contenu par slide remplacé par UN overlay fixe (eyebrow, H1 gradient,
 *      sous-titre, 2 CTA, chip de preuve sociale) — les images tournent dessous.
 *   6. CTA passés sur les classes globales .btn / .btn--primary / .btn--ghost.
 *   7. JS natif préservé (zoom-in, autoplay 6 s, flèches, dots, drag, clavier)
 *      et SCOPÉ à `.ti-herozoom` (supporte 0 ou n instances, aucun getElementById).
 */
import { SITE } from "../../data/site";

export interface Props {
  slides?: { image: string; alt: string }[];
  eyebrow?: string;
  titleStart?: string;
  titleAccent?: string;
  titleEnd?: string;
  sub?: string;
  ctaPrimary?: { label: string; href: string };
  ctaGhost?: { label: string; href: string; external?: boolean };
  trust?: string;
}
const {
  slides = [
    { image: "/img/hero-1.jpg", alt: "Family body-print canvas in red and pink, displayed among plants" },
    { image: "/img/hero-2.jpg", alt: "Couple kissing while wearing matching hand-print t-shirts" },
    { image: "/img/hero-3.jpg", alt: "Man from behind wearing a black tee with a white hug imprint" },
    { image: "/img/hero-4.jpg", alt: "White and silver body-print canvas styled with a sculpture" },
  ],
  eyebrow = "DIY paint-imprint kits",
  titleStart = "Turn your ",
  titleAccent = "touch",
  titleEnd = " into art.",
  sub = "Capture a hug, a kiss, your hands or your whole body — on canvas or a tee. Skin-safe paint, everything in the box, shipped worldwide.",
  ctaPrimary = { label: "Shop the kits", href: "/kits/" },
  ctaGhost = { label: "See the gallery", href: "/gallery/" },
  trust = `★ ${SITE.followers} followers on Instagram · best reel ${SITE.topReelLikes} likes`,
} = Astro.props;
---

<section class="ti-herozoom" data-bleed aria-roledescription="carousel" aria-label="Time Imprints highlights">
  <div class="zm__slides">
    {slides.map((s, k) => (
      <div class={`zm__slide${k === 0 ? " is-on" : ""}`} role="img" aria-label={s.alt}>
        <div class="zm__img" style={`background-image:url('${s.image}')`}></div>
      </div>
    ))}
    <div class="zm__veil" aria-hidden="true"></div>
  </div>

  <div class="zm__inner">
    <div class="zm__content">
      <span class="zm__eyebrow wf-rev" style="--d:0s">{eyebrow}</span>
      <h1 class="zm__title wf-rev" style="--d:.1s">
        {titleStart}<span class="zm__grad">{titleAccent}</span>{titleEnd}
      </h1>
      <p class="zm__sub wf-rev" style="--d:.2s">{sub}</p>
      <div class="zm__ctas wf-rev" style="--d:.3s">
        <a class="btn btn--primary" href={ctaPrimary.href}>
          {ctaPrimary.label}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a
          class="btn btn--ghost"
          href={ctaGhost.href}
          target={ctaGhost.external ? "_blank" : undefined}
          rel={ctaGhost.external ? "noopener" : undefined}
        >{ctaGhost.label}</a>
      </div>
      <p class="zm__trust wf-rev" style="--d:.4s">{trust}</p>
    </div>
  </div>

  <button class="zm__arrow zm__arrow--prev" data-prev aria-label="Previous slide">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <button class="zm__arrow zm__arrow--next" data-next aria-label="Next slide">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
  </button>
  <div class="zm__dots" data-dots role="tablist" aria-label="Choose a slide"></div>
  <div class="zm__count" aria-live="polite"><b data-num>01</b> / <span data-tot>{String(slides.length).padStart(2, "0")}</span></div>
</section>

<style>
  .ti-herozoom {
    --ease: cubic-bezier(.16,1,.3,1);
    --easeBack: cubic-bezier(.34,1.56,.64,1);
    position: relative;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
    background: var(--bg);
    color: var(--fg);
    user-select: none;
    touch-action: pan-y;
  }

  /* --- Slides : images superposées en fondu + zoom-in punchy ------------- */
  .zm__slides { position: absolute; inset: 0; }
  .zm__slide { position: absolute; inset: 0; opacity: 0; transition: opacity .7s var(--ease); z-index: 0; }
  .zm__slide.is-on { opacity: 1; z-index: 1; }
  .zm__img {
    position: absolute; inset: 0; background-size: cover; background-position: center;
    transform: scale(1.4); transition: transform 1.1s var(--ease);
  }
  .zm__slide.is-on .zm__img { transform: scale(1); }
  /* Voile sombre pour le contraste du texte (site sombre) */
  .zm__veil {
    position: absolute; inset: 0; z-index: 2; pointer-events: none;
    background:
      linear-gradient(90deg, color-mix(in srgb, var(--bg) 78%, transparent) 0%, color-mix(in srgb, var(--bg) 30%, transparent) 55%, transparent 100%),
      linear-gradient(180deg, color-mix(in srgb, var(--bg) 35%, transparent) 0%, transparent 30%, transparent 45%, color-mix(in srgb, var(--bg) 86%, transparent) 100%);
  }

  /* --- Contenu ------------------------------------------------------------ */
  .zm__inner {
    position: relative; z-index: 3; height: 100%;
    max-width: var(--container); margin: 0 auto;
    padding: 0 var(--gutter) clamp(4.5rem, 11vh, 7.5rem);
    display: flex; flex-direction: column; justify-content: flex-end;
  }
  .zm__content { max-width: 42rem; }

  .zm__eyebrow {
    display: inline-block; font-size: var(--step--1); font-weight: 600;
    letter-spacing: .2em; text-transform: uppercase; color: var(--accent-2);
    margin-bottom: 1.1rem;
  }
  .zm__title {
    font-size: clamp(2.5rem, 6.4vw, 4.6rem); font-weight: 800;
    line-height: 1.04; letter-spacing: -.025em;
    text-wrap: balance;
  }
  .zm__grad {
    background: linear-gradient(100deg, var(--accent), var(--accent-2));
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent; color: transparent;
  }
  .zm__sub {
    margin-top: 1.2rem; font-size: clamp(1rem, 1.4vw, 1.2rem); line-height: 1.6;
    color: color-mix(in srgb, var(--fg) 86%, transparent); max-width: 36rem;
  }
  .zm__ctas { margin-top: 2rem; display: flex; flex-wrap: wrap; gap: .8rem; align-items: center; }
  .zm__ctas .btn svg { width: 1.05rem; height: 1.05rem; }
  .zm__trust {
    margin-top: 1.4rem; display: inline-flex; align-items: center; gap: .5rem;
    font-size: var(--step--1); font-weight: 500;
    color: color-mix(in srgb, var(--fg) 80%, transparent);
    padding: .45rem .95rem; border-radius: 99px;
    border: 1px solid color-mix(in srgb, var(--fg) 22%, transparent);
    background: color-mix(in srgb, var(--bg) 45%, transparent);
    backdrop-filter: blur(8px);
  }

  /* --- Cascade du contenu à chaque arrivée de slide / au chargement ------- */
  .wf-js .wf-rev { opacity: 0; transform: translateY(26px); transition: opacity .8s var(--ease), transform .85s var(--easeBack); transition-delay: var(--d, 0s); }
  .wf-js .wf-rev.is-in { opacity: 1; transform: none; }

  /* --- Contrôles ----------------------------------------------------------- */
  .zm__arrow {
    position: absolute; top: 50%; transform: translateY(-50%); z-index: 5;
    width: 3rem; height: 3rem; border-radius: 50%; display: grid; place-items: center;
    background: color-mix(in srgb, var(--fg) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--fg) 34%, transparent);
    color: var(--fg); backdrop-filter: blur(8px); cursor: pointer;
    font: inherit; padding: 0;
    transition: background .2s, color .2s;
  }
  .zm__arrow:hover { background: var(--fg); color: var(--bg); }
  .zm__arrow svg { width: 1.1rem; height: 1.1rem; }
  .zm__arrow--prev { left: clamp(.8rem, 2vw, 1.6rem); }
  .zm__arrow--next { right: clamp(.8rem, 2vw, 1.6rem); }

  .zm__dots { position: absolute; left: var(--gutter); bottom: 1.5rem; z-index: 5; display: flex; gap: .5rem; }
  .zm__dots :global(.zm__dot) {
    width: 22px; height: 3px; border-radius: 2px; border: 0; padding: 0; cursor: pointer;
    background: color-mix(in srgb, var(--fg) 40%, transparent);
    transition: .3s var(--ease);
  }
  .zm__dots :global(.zm__dot.is-on) { background: linear-gradient(90deg, var(--accent), var(--accent-2)); width: 42px; }

  .zm__count {
    position: absolute; right: var(--gutter); bottom: 1.35rem; z-index: 5;
    font-size: .85rem; font-weight: 600;
    color: color-mix(in srgb, var(--fg) 80%, transparent);
    font-variant-numeric: tabular-nums;
  }
  .zm__count b { color: var(--fg); }

  /* --- Responsive ----------------------------------------------------------- */
  @media (max-width: 640px) {
    .zm__arrow { display: none; }
    .zm__count { display: none; }
    .zm__ctas .btn { flex: 1 1 auto; justify-content: center; }
  }

  /* --- Accessibilité ---------------------------------------------------------- */
  :focus-visible { outline: 2px solid var(--accent-2); outline-offset: 3px; border-radius: .4rem; }
  @media (prefers-reduced-motion: reduce) {
    .zm__slide { transition: none; }
    .zm__img { transition: none; transform: none; }
    .wf-js .wf-rev { opacity: 1 !important; transform: none !important; transition: none !important; }
  }
</style>

<script>
  document.documentElement.classList.add("wf-js");
  (function () {
    var rm = window.matchMedia("(prefers-reduced-motion:reduce)").matches;

    [].forEach.call(document.querySelectorAll(".ti-herozoom"), function (zm: HTMLElement) {
      /* Cascade du contenu au chargement */
      var revs = [].slice.call(zm.querySelectorAll(".wf-rev"));
      requestAnimationFrame(function () {
        revs.forEach(function (el: Element) { el.classList.add("is-in"); });
      });

      /* Slider */
      var slides = [].slice.call(zm.querySelectorAll(".zm__slide"));
      var n = slides.length;
      if (n < 2) return;

      var dotsBox = zm.querySelector("[data-dots]") as HTMLElement | null;
      var num = zm.querySelector("[data-num]") as HTMLElement | null;
      var i = 0, paused = false, DUR = 6000;
      var timer: ReturnType<typeof setTimeout> | undefined;

      var dots: HTMLElement[] = [];
      if (dotsBox) {
        slides.forEach(function (_: Element, k: number) {
          var d = document.createElement("button");
          d.className = "zm__dot" + (k === 0 ? " is-on" : "");
          d.setAttribute("role", "tab");
          d.setAttribute("aria-label", "Slide " + (k + 1));
          d.addEventListener("click", function () { paused = true; go(k); });
          dotsBox!.appendChild(d);
        });
        dots = [].slice.call(dotsBox.children);
      }

      function go(k: number) {
        i = (k + n) % n;
        slides.forEach(function (s: Element, j: number) { s.classList.toggle("is-on", j === i); });
        dots.forEach(function (d, j) { d.classList.toggle("is-on", j === i); });
        if (num) num.textContent = String(i + 1).padStart(2, "0");
        schedule();
      }
      function schedule() {
        clearTimeout(timer);
        if (!paused && !rm) timer = setTimeout(function () { go(i + 1); }, DUR);
      }

      var prev = zm.querySelector("[data-prev]");
      var next = zm.querySelector("[data-next]");
      if (prev) prev.addEventListener("click", function () { paused = true; go(i - 1); });
      if (next) next.addEventListener("click", function () { paused = true; go(i + 1); });

      zm.tabIndex = 0;
      zm.addEventListener("keydown", function (e: KeyboardEvent) {
        if (e.key === "ArrowLeft") { paused = true; go(i - 1); }
        else if (e.key === "ArrowRight") { paused = true; go(i + 1); }
      });
      zm.addEventListener("mouseenter", function () { clearTimeout(timer); });
      zm.addEventListener("mouseleave", function () { if (!paused) schedule(); });

      var sx = 0, down = false;
      zm.addEventListener("pointerdown", function (e: PointerEvent) {
        if ((e.target as HTMLElement).closest("button,a")) return;
        down = true; sx = e.clientX; clearTimeout(timer);
      });
      zm.addEventListener("pointerup", function (e: PointerEvent) {
        if (!down) return;
        down = false;
        var dx = e.clientX - sx;
        if (Math.abs(dx) > 50) { paused = true; go(dx < 0 ? i + 1 : i - 1); }
        else schedule();
      });

      schedule();
    });
  })();
</script>
