---
/**
 * Integration — section `grid_products-filter-category` (full catalogue, /kits/).
 * Normal section (non bleed). Phase 2 rules applied:
 *   1. Local `:root` tokens, reset and Google-Fonts markup removed → base tokens.
 *   2. Vertical padding removed → base `--section-y` rhythm.
 *   3. Hard-coded colors → theme tokens (--surface, --line, --accent,
 *      --shadow-color, color-mix tints).
 *   4. Eyebrow removed (typo sobriety rule).
 *   5. Filters mapped to Product.category: all / canvas / tshirt. Cards fed
 *      from PRODUCTS — image, badge, category chip, name, short, EUR + UAH
 *      price, "View kit" + "Add to cart" CTAs. Add-ons note under the grid.
 *   6. Reveal-on-scroll kept (.wf-rev + IntersectionObserver + reduced-motion
 *      fallback), with the anti-disappearance guard: a card re-shown by a
 *      filter click gets .is-in immediately.
 *   7. JS scoped per instance via `.ti-kitgrid` (safe with 0 or 2+ instances).
 *      `.wf-js` (set on <html>) referenced via :global() so scoping can't
 *      break the reveal gate.
 */
import { PRODUCTS, type Product } from "../../data/site";

export interface Props {
  title?: string;
  products?: Product[];
}
const { title = "All kits", products = PRODUCTS } = Astro.props;
const catLabel = (c: Product["category"]) => (c === "canvas" ? "Canvas" : "T-shirt");
---

<section class="ti-kitgrid" aria-label={title}>
  <div class="inner">
    <header class="head wf-rev">
      <h2 class="head__title" data-slot="titre">{title}</h2>
    </header>

    <div class="filters" role="group" aria-label="Filter kits by category">
      <button class="filter" type="button" data-filter="all" aria-pressed="true">All kits</button>
      <button class="filter" type="button" data-filter="canvas" aria-pressed="false">Canvas</button>
      <button class="filter" type="button" data-filter="tshirt" aria-pressed="false">T-shirts</button>
      <span class="count" aria-live="polite"></span>
    </div>

    <div class="grid" data-slot="produits">
      {products.map((p) => (
        <article class="product wf-rev" data-cat={p.category} data-slot-item>
          <a class="product__media" href={`/kits/${p.slug}/`} tabindex="-1">
            <img src={p.image} alt={p.name} loading="lazy" />
            {p.badge && <span class="product__badge">{p.badge}</span>}
          </a>
          <div class="product__body">
            <span class="product__cat">{catLabel(p.category)}</span>
            <h3 class="product__name">{p.name}</h3>
            <p class="product__short">{p.short}</p>
            <p class="product__price">€{p.priceEur} <small>≈ {p.priceUah} ₴</small></p>
            <div class="product__ctas">
              <a class="btn btn--ghost product__btn" href={`/kits/${p.slug}/`}>View kit</a>
              <button
                type="button"
                class="btn btn--primary product__btn"
                data-add-to-cart
                data-slug={p.slug}
                data-name={p.name}
                data-price={p.priceEur}
                data-image={p.image}
                data-label-original="Add to cart"
              >Add to cart</button>
            </div>
          </div>
        </article>
      ))}
    </div>

    <p class="addons wf-rev">
      Add-ons: extra canvas +6 € · extra paint jar +2.5 € — add a note at checkout.
    </p>
  </div>
</section>

<style>
  .ti-kitgrid { --ease: cubic-bezier(.16,1,.3,1); --easeBack: cubic-bezier(.34,1.56,.64,1); color: var(--fg); }
  .inner { width: 100%; max-width: var(--container); margin: 0 auto; padding-inline: var(--gutter); }

  .head { margin-bottom: 1.4rem; }
  .head__title { font-size: clamp(1.7rem, 3.6vw, 2.4rem); font-weight: 800; letter-spacing: -.025em; }

  .filters { display: flex; flex-wrap: wrap; gap: .5rem; align-items: center; margin-bottom: 1.6rem; }
  .filter {
    border: 1px solid var(--line); background: var(--surface); color: var(--muted);
    font-weight: 600; font-size: .95rem; padding: .5rem 1.1rem; border-radius: 99px;
    cursor: pointer; transition: .25s var(--ease);
  }
  .filter[aria-pressed="true"] { background: var(--accent); color: var(--accent-contrast); border-color: var(--accent); }
  .count { margin-left: auto; font-size: .85rem; color: var(--muted); }

  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; }

  .product {
    position: relative; background: var(--surface); border: 1px solid var(--line);
    border-radius: var(--radius); overflow: hidden; isolation: isolate;
    display: flex; flex-direction: column;
    transition: opacity .45s var(--ease), transform .45s var(--ease), box-shadow .45s var(--ease),
      border-color .35s var(--ease), filter .45s var(--ease);
  }
  .product.is-hidden { display: none; }

  /* light spot that follows the cursor on the active card */
  .product::after {
    content: ""; position: absolute; inset: 0; border-radius: inherit; pointer-events: none; z-index: 3;
    background: radial-gradient(340px circle at var(--mx, 50%) var(--my, 50%),
      color-mix(in srgb, var(--accent) 12%, transparent), transparent 60%);
    opacity: 0; transition: opacity .35s var(--ease);
  }

  .product__media {
    position: relative; display: block; aspect-ratio: 4 / 3;
    background: color-mix(in srgb, var(--fg) 6%, var(--bg)); overflow: hidden;
  }
  .product__media img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s var(--ease); }
  .product__badge {
    position: absolute; top: .8rem; left: .8rem;
    background: var(--accent); color: var(--accent-contrast);
    font-size: .72rem; font-weight: 700; letter-spacing: .04em; text-transform: uppercase;
    padding: .3rem .7rem; border-radius: 999px;
  }

  .product__body { padding: 1.1rem 1.2rem 1.3rem; display: flex; flex-direction: column; flex: 1; }
  .product__cat {
    font-size: .74rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase;
    color: var(--accent-2);
  }
  .product__name { font-size: 1.15rem; font-weight: 700; letter-spacing: -.01em; margin-top: .25rem; }
  .product__short { color: var(--muted); font-size: .92rem; line-height: 1.55; margin-top: .35rem; }
  .product__price { margin-top: .8rem; font-weight: 800; letter-spacing: -.02em; font-size: 1.25rem; }
  .product__price small { font-size: .82rem; font-weight: 500; color: var(--muted); }
  .product__ctas { display: flex; gap: .55rem; flex-wrap: wrap; margin-top: auto; padding-top: 1rem; }
  .product__btn { min-height: 40px; padding: .5em 1.1em; font-size: .9rem; border-radius: calc(var(--radius) * .6); }
  .product__btn.btn--primary { flex: 1; }

  .addons { margin-top: 1.8rem; font-size: .9rem; color: var(--muted); }
  .addons a { color: var(--accent-2); }

  /* Hover focus (spotlight accordion) */
  @media (hover: hover) and (pointer: fine) {
    .filter:not([aria-pressed="true"]):hover { border-color: var(--accent); color: var(--accent); }
    .product:hover {
      transform: scale(1.03) translateY(-4px);
      border-color: color-mix(in srgb, var(--accent) 45%, var(--line));
      box-shadow: 0 30px 56px -26px var(--shadow-color); z-index: 2;
    }
    .product:hover::after { opacity: 1; }
    .product:hover .product__media img { transform: scale(1.08); }
    /* neighbours step back — coexists with the filter (.is-hidden stays display:none);
       graceful degradation: without :has(), only the direct hover applies */
    .grid:has(.product:hover) .product:not(:hover) { transform: scale(.98); opacity: .6; filter: saturate(.7); }
  }

  /* Reveal on scroll — coexists with the filter.
     ANTI-DISAPPEARANCE GUARD: the hidden state lives ONLY in
     .wf-rev:not(.is-in); the filter (.is-hidden → display:none) always wins,
     and a product re-shown by a filter click gets .is-in immediately. */
  :global(.wf-js) .wf-rev:not(.is-in) { opacity: 0; transform: translateY(46px) scale(.93); filter: blur(6px); }
  :global(.wf-js) .head.wf-rev,
  :global(.wf-js) .addons.wf-rev { transition: opacity .8s var(--ease), transform .9s var(--easeBack), filter .8s var(--ease); }
  :global(.wf-js) .product.wf-rev:not(.is-in) {
    transition: opacity .8s var(--ease), transform .9s var(--easeBack), filter .8s var(--ease);
    transition-delay: var(--d, 0s);
  }
  :global(.wf-js) .wf-rev.is-in { opacity: 1; transform: none; filter: none; }
  /* exit "variant B" — mirror of the entry, upwards (scrolled past the top) */
  :global(.wf-js) .wf-rev.wf-exit-up { opacity: 0; transform: translateY(-46px) scale(.93); filter: blur(6px); }
  :global(.wf-js) .grid .product:nth-child(1) { --d: .06s; }
  :global(.wf-js) .grid .product:nth-child(2) { --d: .13s; }
  :global(.wf-js) .grid .product:nth-child(3) { --d: .20s; }
  :global(.wf-js) .grid .product:nth-child(4) { --d: .27s; }
  :global(.wf-js) .grid .product:nth-child(5) { --d: .34s; }
  :global(.wf-js) .grid .product:nth-child(6) { --d: .41s; }
  :global(.wf-js) .grid .product:nth-child(7) { --d: .48s; }
  :global(.wf-js) .grid .product:nth-child(8) { --d: .55s; }

  @media (max-width: 900px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) {
    .grid { grid-template-columns: 1fr; }
    .count { width: 100%; margin: .3rem 0 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    * { transition: none !important; animation: none !important; }
    :global(.wf-js) .wf-rev { opacity: 1 !important; transform: none !important; filter: none !important; }
    .product:hover { transform: none !important; }
    .grid:has(.product:hover) .product:not(:hover) { transform: none !important; opacity: 1 !important; filter: none !important; }
    .product::after { display: none !important; }
  }
</style>

<script>
  document.documentElement.classList.add("wf-js");
  document.querySelectorAll<HTMLElement>(".ti-kitgrid").forEach((root) => {
    const filters = Array.from(root.querySelectorAll<HTMLButtonElement>(".filter"));
    const products = Array.from(root.querySelectorAll<HTMLElement>(".product"));
    const count = root.querySelector<HTMLElement>(".count");

    function apply(f: string, forceIn: boolean) {
      let n = 0;
      products.forEach((p) => {
        const show = f === "all" || p.dataset.cat === f;
        p.classList.toggle("is-hidden", !show);
        if (show) {
          n++;
          /* on a filter click (forceIn), a re-shown product must never come
             back invisible because of the reveal: .is-in is set and stays.
             (Not on first load: the observer plays the scroll reveal.) */
          if (forceIn) p.classList.add("is-in");
        }
      });
      if (count) count.textContent = n + (n === 1 ? " kit" : " kits");
    }
    filters.forEach((b) => {
      b.addEventListener("click", () => {
        filters.forEach((x) => x.setAttribute("aria-pressed", String(x === b)));
        apply(b.dataset.filter || "all", true);
      });
    });
    apply("all", false);

    /* Reveal on scroll: header + cards + add-ons note. */
    const reduce = window.matchMedia("(prefers-reduced-motion:reduce)").matches;
    const els = Array.from(root.querySelectorAll(".wf-rev"));
    if (reduce || !("IntersectionObserver" in window)) {
      els.forEach((el) => el.classList.add("is-in"));
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("is-in");
              e.target.classList.remove("wf-exit-up");
            } else {
              e.target.classList.remove("is-in");
              e.target.classList.toggle("wf-exit-up", e.boundingClientRect.top < 0);
            }
          });
        },
        { threshold: 0.15 }
      );
      els.forEach((el) => io.observe(el));
    }

    /* Cursor spotlight on the active card (fine pointer, no reduced motion).
       Independent from the filter: touches neither .is-hidden nor .is-in. */
    if (reduce || !window.matchMedia("(hover:hover) and (pointer:fine)").matches) return;
    products.forEach((card) => {
      card.addEventListener("mousemove", (e) => {
        const r = card.getBoundingClientRect();
        card.style.setProperty("--mx", (((e.clientX - r.left) / r.width) * 100).toFixed(1) + "%");
        card.style.setProperty("--my", (((e.clientY - r.top) / r.height) * 100).toFixed(1) + "%");
      });
    });
  });
</script>
