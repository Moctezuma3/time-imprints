---
/**
 * Integration — section `carrousel_products-featured-carousel`, REPURPOSED as
 * the product-detail hero ("ProductHero", conversion core of /kits/<slug>/).
 * Normal section (non bleed). Phase 2 rules applied:
 *   1. Local `:root` tokens, reset and Google-Fonts markup removed → base tokens.
 *   2. Vertical padding removed → base `--section-y` rhythm.
 *   3. Hard-coded colors → theme tokens; the price wears the brand
 *      pink→cyan gradient (--accent → --accent-2).
 *   4. Eyebrow + centred header removed; H1 lives here (top of product page).
 *   5. Carousel slides → ONE product, two columns: gallery (main image +
 *      thumbnails, click swaps with a crossfade — adapted from the carousel
 *      JS, incl. ← → keyboard support) and buying column (badge, name, price,
 *      description, contents checklist, paint-color swatches, sizes note,
 *      add-ons, CTAs, trust chips).
 *   6. JS scoped per instance via `.ti-producthero` (safe with 0 or 2+ instances).
 */
import { type Product } from "../../data/site";

export interface Props {
  product: Product;
}
const { product } = Astro.props;
const SIZES = ["S", "M", "L", "XL"];

/** Paint-color names → visible swatch dots. */
const COLOR_HEX: Record<string, string> = {
  Orange: "#f0954f",
  Green: "#9fd6a8",
  "Sky blue": "#7fd4f0",
  Gold: "#e8c454",
  Pink: "#f2a0c8",
  Silver: "#d9dde4",
  Black: "#1c1c22",
  White: "#f5f5f5",
  Red: "#e04545",
};
const gallery = product.gallery && product.gallery.length ? product.gallery : [product.image];
---

<section class="ti-producthero" aria-label={`${product.name} — details and ordering`}>
  <div class="ph__inner">
    <div class="ph__gallery">
      <figure class="ph__main">
        <img class="ph__img" src={gallery[0]} alt={product.name} fetchpriority="high" />
      </figure>
      {gallery.length > 1 && (
        <div class="ph__thumbs" role="group" aria-label={`${product.name} photos`}>
          {gallery.map((src, i) => (
            <button
              class="ph__thumb"
              type="button"
              data-src={src}
              aria-label={`Show photo ${i + 1} of ${gallery.length}`}
              aria-current={i === 0 ? "true" : "false"}
            >
              <img src={src} alt="" loading="lazy" />
            </button>
          ))}
        </div>
      )}
    </div>

    <div class="ph__body">
      {product.badge && <span class="ph__badge" data-field="badge">{product.badge}</span>}
      <h1 class="ph__title" data-field="titre">{product.name}</h1>
      <p class="ph__price">
        <span class="ph__eur">€{product.priceEur}</span>
        <span class="ph__uah">{product.priceUah} ₴</span>
      </p>
      <p class="ph__desc" data-field="description">{product.description}</p>

      <h2 class="ph__label">What's in the box</h2>
      <ul class="ph__list">
        {product.contents.map((item) => (
          <li>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12l4 4L19 6" /></svg>
            {item}
          </li>
        ))}
      </ul>

      <h2 class="ph__label">Paint colors</h2>
      <div class="ph__swatches">
        {product.colors.map((c) => (
          <span class="ph__swatch">
            <i style={`background:${COLOR_HEX[c] ?? "var(--muted)"}`} aria-hidden="true"></i>
            {c}
          </span>
        ))}
      </div>

      {product.category === "tshirt" && (
        <>
          <h2 class="ph__label">Size <span class="ph__labelnote">100% cotton</span></h2>
          <div class="ph__sizes" role="group" aria-label="Choose your t-shirt size">
            {SIZES.map((s) => (
              <button type="button" class="ph__size" data-size={s} aria-pressed={s === "M" ? "true" : "false"}>{s}</button>
            ))}
          </div>
        </>
      )}

      {product.options && product.options.length > 0 && (
        <>
          <h2 class="ph__label">Add-ons</h2>
          <ul class="ph__options">
            {product.options.map((o) => (
              <li>{o}</li>
            ))}
          </ul>
        </>
      )}

      <div class="ph__buy">
        <div class="ph__qty" role="group" aria-label="Quantity">
          <button type="button" class="ph__qtybtn" data-qty-dec aria-label="Decrease quantity">−</button>
          <span class="ph__qtyval" data-qty-val>1</span>
          <button type="button" class="ph__qtybtn" data-qty-inc aria-label="Increase quantity">+</button>
        </div>
        <button
          type="button"
          class="btn btn--primary ph__add"
          data-slug={product.slug}
          data-name={product.name}
          data-price={product.priceEur}
          data-image={product.image}
        >Add to cart · €{product.priceEur}</button>
      </div>
      <button
        type="button"
        class="btn btn--ghost ph__buynow"
        data-slug={product.slug}
        data-name={product.name}
        data-price={product.priceEur}
        data-image={product.image}
      >Buy it now</button>

      <ul class="ph__trust" aria-label="Good to know">
        <li>Skin-safe paint</li>
        <li>Ships worldwide</li>
        <li>Gift-ready box</li>
      </ul>
    </div>
  </div>
</section>

<style>
  .ti-producthero { --ease: cubic-bezier(.16,1,.3,1); color: var(--fg); }
  .ph__inner {
    width: 100%; max-width: var(--container); margin: 0 auto; padding-inline: var(--gutter);
    display: grid; grid-template-columns: 1.05fr .95fr; gap: clamp(1.6rem, 4vw, 3.4rem);
    align-items: start;
  }

  /* — gallery — */
  .ph__main {
    border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden;
    background: color-mix(in srgb, var(--fg) 6%, var(--bg));
  }
  .ph__img { width: 100%; aspect-ratio: 1 / 1; object-fit: cover; transition: opacity .18s var(--ease); }
  .ph__img.is-fading { opacity: 0; }
  .ph__thumbs { display: flex; flex-wrap: wrap; gap: .6rem; margin-top: .8rem; }
  .ph__thumb {
    width: 4.4rem; height: 4.4rem; padding: 0; overflow: hidden; cursor: pointer;
    border: 1px solid var(--line); border-radius: calc(var(--radius) * .6);
    background: var(--surface); opacity: .65;
    transition: opacity .2s, border-color .2s;
  }
  .ph__thumb img { width: 100%; height: 100%; object-fit: cover; }
  .ph__thumb[aria-current="true"] { border-color: var(--accent); opacity: 1; }

  /* — buying column — */
  .ph__badge {
    display: inline-flex; align-self: flex-start;
    background: color-mix(in srgb, var(--accent) 16%, transparent); color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
    font-size: .78rem; font-weight: 700; letter-spacing: .05em; text-transform: uppercase;
    padding: .35rem .8rem; border-radius: 999px; margin-bottom: 1rem;
  }
  .ph__title { font-size: clamp(2rem, 4.4vw, 3rem); font-weight: 800; letter-spacing: -.02em; line-height: 1.08; }
  .ph__price { display: flex; align-items: baseline; gap: .7rem; margin-top: .9rem; }
  .ph__eur {
    font-size: clamp(1.9rem, 3.4vw, 2.5rem); font-weight: 800; letter-spacing: -.02em;
    background: linear-gradient(90deg, var(--accent), var(--accent-2));
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .ph__uah { color: var(--muted); font-size: 1.05rem; font-weight: 600; }
  .ph__desc { color: var(--muted); line-height: 1.65; margin-top: 1rem; max-width: 38rem; }

  .ph__label {
    font-size: .82rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
    color: var(--fg); margin: 1.7rem 0 .7rem;
  }
  .ph__list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: .5rem; }
  .ph__list li { display: flex; align-items: flex-start; gap: .55rem; font-size: .95rem; line-height: 1.5; }
  .ph__list svg {
    width: 1.1rem; height: 1.1rem; flex: none; margin-top: .2em;
    fill: none; stroke: var(--accent); stroke-width: 2.4; stroke-linecap: round; stroke-linejoin: round;
  }

  .ph__swatches { display: flex; flex-wrap: wrap; gap: .5rem; }
  .ph__swatch {
    display: inline-flex; align-items: center; gap: .45rem;
    border: 1px solid var(--line); background: var(--surface); border-radius: 999px;
    padding: .32rem .8rem .32rem .45rem; font-size: .85rem; font-weight: 600;
  }
  .ph__swatch i {
    display: block; width: 1rem; height: 1rem; border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--fg) 25%, transparent);
  }

  .ph__labelnote { font-weight: 500; text-transform: none; letter-spacing: 0; color: var(--muted); margin-left: .5rem; }

  .ph__sizes { display: flex; flex-wrap: wrap; gap: .5rem; }
  .ph__size {
    min-width: 3rem; padding: .55rem .9rem; cursor: pointer; font-weight: 700; font-size: .92rem;
    border: 1px solid var(--line); border-radius: calc(var(--radius) * .55);
    background: var(--surface); color: var(--fg); transition: border-color .2s, background .2s, color .2s;
  }
  .ph__size:hover { border-color: color-mix(in srgb, var(--accent) 45%, var(--line)); }
  .ph__size[aria-pressed="true"] {
    border-color: var(--accent); color: var(--accent-contrast);
    background: linear-gradient(90deg, var(--accent), var(--accent-2));
  }

  .ph__options { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: .5rem; }
  .ph__options li {
    color: var(--muted); font-size: .88rem;
    border: 1px dashed var(--line); border-radius: 999px; padding: .3rem .85rem;
  }

  .ph__buy { display: flex; flex-wrap: wrap; gap: .8rem; margin-top: 1.9rem; align-items: stretch; }
  .ph__qty {
    display: inline-flex; align-items: center; gap: .3rem; flex: none;
    border: 1px solid var(--line); border-radius: var(--radius); padding: .25rem .35rem;
  }
  .ph__qtybtn {
    width: 2.2rem; height: 2.2rem; border: none; background: none; color: var(--fg);
    font-size: 1.2rem; cursor: pointer; border-radius: 50%; line-height: 1;
  }
  .ph__qtybtn:hover { background: color-mix(in srgb, var(--fg) 10%, transparent); }
  .ph__qtyval { min-width: 1.6rem; text-align: center; font-weight: 800; font-size: 1.05rem; }
  .ph__add { flex: 1; min-width: 12rem; }
  .ph__buynow { width: 100%; margin-top: .8rem; }

  .ph__trust {
    list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: .5rem 1.4rem;
    margin-top: 1.4rem; color: var(--muted); font-size: .85rem;
  }
  .ph__trust li::before { content: "✓ "; color: var(--accent-2); font-weight: 700; }

  @media (hover: hover) and (pointer: fine) {
    .ph__thumb:hover { opacity: 1; border-color: color-mix(in srgb, var(--accent) 45%, var(--line)); }
  }

  @media (max-width: 900px) {
    .ph__inner { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .ph__thumbs, .ph__swatches, .ph__sizes, .ph__buy, .ph__trust, .ph__options { justify-content: center; }
    .ph__badge { align-self: center; }
    .ph__price { justify-content: center; }
    .ph__list li { text-align: left; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ph__img, .ph__thumb, .ph__size { transition: none; }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>(".ti-producthero").forEach((root) => {
    const main = root.querySelector<HTMLImageElement>(".ph__img");
    const thumbs = Array.from(root.querySelectorAll<HTMLButtonElement>(".ph__thumb"));
    if (!main || !thumbs.length) return;

    const reduce = window.matchMedia("(prefers-reduced-motion:reduce)").matches;
    let i = 0;

    function mark() {
      thumbs.forEach((t, x) => t.setAttribute("aria-current", String(x === i)));
    }
    function go(k: number) {
      i = (k + thumbs.length) % thumbs.length;
      mark();
      const src = thumbs[i].dataset.src;
      if (!src || main!.getAttribute("src") === src) return;
      if (reduce) {
        main!.src = src;
        return;
      }
      main!.classList.add("is-fading");
      window.setTimeout(() => {
        main!.src = src;
        main!.classList.remove("is-fading");
      }, 180);
    }

    thumbs.forEach((t, k) => t.addEventListener("click", () => go(k)));
    /* keyboard ← → within the gallery, kept from the carousel */
    root.querySelector<HTMLElement>(".ph__gallery")?.addEventListener("keydown", (e) => {
      if (e.key === "ArrowLeft") go(i - 1);
      else if (e.key === "ArrowRight") go(i + 1);
    });
  });

  /* Buying controls: size, quantity, add-to-cart / buy-now → window.TICart */
  document.querySelectorAll<HTMLElement>(".ti-producthero").forEach((root) => {
    const sizeBtns = Array.from(root.querySelectorAll<HTMLButtonElement>(".ph__size"));
    const qtyVal = root.querySelector<HTMLElement>("[data-qty-val]");
    const dec = root.querySelector<HTMLButtonElement>("[data-qty-dec]");
    const inc = root.querySelector<HTMLButtonElement>("[data-qty-inc]");
    const add = root.querySelector<HTMLButtonElement>(".ph__add");
    const buy = root.querySelector<HTMLButtonElement>(".ph__buynow");
    let qty = 1;

    sizeBtns.forEach((b) =>
      b.addEventListener("click", () => {
        sizeBtns.forEach((x) => x.setAttribute("aria-pressed", String(x === b)));
      })
    );
    function selectedSize() {
      const on = sizeBtns.find((b) => b.getAttribute("aria-pressed") === "true");
      return on ? on.dataset.size || "" : "";
    }
    function setQty(q: number) { qty = Math.max(1, q); if (qtyVal) qtyVal.textContent = String(qty); }
    dec?.addEventListener("click", () => setQty(qty - 1));
    inc?.addEventListener("click", () => setQty(qty + 1));

    function itemFrom(btn: HTMLElement) {
      return {
        slug: btn.dataset.slug || "",
        name: btn.dataset.name || "",
        image: btn.dataset.image || "",
        price: btn.dataset.price || "0",
        size: selectedSize(),
      };
    }
    const cart = () => (window as any).TICart;
    add?.addEventListener("click", () => {
      const c = cart(); if (!c) return;
      c.add(itemFrom(add), qty);
      c.open();
    });
    buy?.addEventListener("click", () => {
      const c = cart(); if (!c) return;
      c.add(itemFrom(buy), qty);
      window.location.href = "/checkout/";
    });
  });
</script>
