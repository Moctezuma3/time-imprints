---
/**
 * Integration — section `galerie_behind-the-scenes` (normal section, not bleed).
 * Phase 2 rules applied:
 *   1. Local :root + warm-paper body background removed → dark theme tokens.
 *   2. Local reset + Google Fonts import removed.
 *   3. Internal vertical padding removed → the base gives `--section-y` rhythm.
 *   4. Eyebrow removed (typographic sobriety rule).
 *   5. Polaroid paper/ink built with color-mix() from tokens so the white
 *      frames pop on the near-black page; shadows → --shadow-color; the
 *      pinned handwritten note uses --accent (hot pink).
 *   6. Grid layout FIX vs library file: the note was mid-DOM and overlapped
 *      frame 6 (and shifted the nth-child placements). Note now sits LAST in
 *      the DOM and all 9 children get explicit, non-overlapping areas in a
 *      clean 4×4 grid.
 *   7. JS scoped to `.ti-polaroids` roots; enter/exit-up reveal kept.
 *      `html.wf-js`-gated selectors wrapped in :global() so Astro scoping
 *      doesn't sever them from the <html> element.
 */
export interface Props {
  title?: string;
  subtitle?: string;
  note?: string;
  photos?: { image: string; caption: string; alt?: string }[];
}
const {
  title = "Already painted. Ready to love.",
  subtitle = "Finished canvases from our studio — styled, sealed and ready to ship. Each one is a single original: DM us on Instagram and it's yours.",
  note = "One of one.\nAlways.",
  photos = [
    { image: "/img/painting-01.jpg", caption: "Fresh off the easel", alt: "Finished body print canvas resting on an easel" },
    { image: "/img/painting-02.jpg", caption: "Date night result", alt: "Couple print canvas styled after a date night" },
    { image: "/img/painting-03.jpg", caption: "Roses & red prints", alt: "Red print canvas styled with roses" },
    { image: "/img/painting-04.jpg", caption: "Under the fairy lights", alt: "Print canvas glowing under fairy lights" },
    { image: "/img/painting-05.jpg", caption: "Velvet & crimson", alt: "Crimson body print canvas on velvet backdrop" },
    { image: "/img/painting-06.jpg", caption: "Silver, hands & lips", alt: "Silver hand and lip prints on a dark canvas" },
    { image: "/img/painting-07.jpg", caption: "Pink meets cyan", alt: "Pink and cyan body print canvas" },
    { image: "/img/painting-08.jpg", caption: "Gold for their anniversary", alt: "Gold anniversary print canvas" },
  ],
} = Astro.props;
---

<section class="ti-polaroids">
  <div class="bts__inner">

    <header class="bts__head">
      <h2 class="bts__title" data-slot="titre">{title}</h2>
      <p class="bts__sub" data-slot="texte">{subtitle}</p>
    </header>

    <div class="grid" data-slot="images">
      {photos.map((p) => (
        <figure class="frame wf-rev" data-slot-item>
          <div class="frame__img"><img loading="lazy" src={p.image} alt={p.alt ?? p.caption} data-field="image" /></div>
          <figcaption class="frame__cap" data-field="legende">{p.caption}</figcaption>
        </figure>
      ))}
      <p class="note note--accent wf-rev">{note}</p>
    </div>

  </div>
</section>

<style>
  .ti-polaroids {
    --ease: cubic-bezier(.16,1,.3,1);
    --easeBack: cubic-bezier(.34,1.56,.64,1);
    --paper: color-mix(in srgb, var(--accent-contrast) 94%, var(--bg));
    --ink: color-mix(in srgb, var(--bg) 86%, var(--accent-contrast));
    --font-hand: Georgia, "Times New Roman", serif;   /* italic serif for the notes */
    color: var(--fg);
  }
  .bts__inner { width: 100%; max-width: min(66rem, var(--container)); margin: 0 auto; padding-inline: var(--gutter); }

  .bts__head { max-width: 38rem; margin-bottom: 2.5rem; }
  .bts__title { font-size: var(--step-3); font-weight: 800; letter-spacing: -.025em; line-height: 1.1; }
  .bts__sub { margin-top: .8rem; color: var(--muted); line-height: 1.6; font-size: var(--step-0); }

  /* asymmetric CSS Grid mosaic — 4×4, explicit non-overlapping placements */
  .grid {
    display: grid; gap: 1.4rem 1.2rem;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: minmax(10rem, auto);
  }

  .frame {
    background: var(--paper);
    padding: .7rem .7rem 1.1rem; margin: 0;
    border-radius: .2rem;
    box-shadow: 0 14px 26px -16px var(--shadow-color);
    display: flex; flex-direction: column; gap: .5rem;
    transform: rotate(var(--r, 0deg));
    transition: transform .35s var(--ease), box-shadow .35s var(--ease);
  }
  .frame:hover {
    transform: rotate(var(--r, 0deg)) translateY(-4px) scale(1.015);
    box-shadow: 0 24px 44px -20px var(--shadow-color);
  }
  .frame__img { flex: 1; overflow: hidden; border-radius: .1rem; background: color-mix(in srgb, var(--ink) 12%, var(--paper)); min-height: 0; }
  .frame__img img { display: block; width: 100%; height: 100%; object-fit: cover; transition: transform .6s var(--ease); }
  @media (hover: hover) and (pointer: fine) {
    .frame:hover .frame__img img { transform: scale(1.06); }   /* soft zoom, frame clips */
  }
  .frame__cap {
    font-family: var(--font-hand); font-style: italic; font-size: 1.05rem;
    line-height: 1.2; text-align: center; color: var(--ink);
  }

  /* placements: frames are children 1–8, the pinned note is child 9 */
  .frame:nth-child(1) { grid-column: 1/3; grid-row: 1/3; --r: -1.4deg; }
  .frame:nth-child(2) { grid-column: 3/4; grid-row: 1/2; --r: 1.8deg; }
  .frame:nth-child(3) { grid-column: 4/5; grid-row: 1/3; --r: -1deg; }
  .frame:nth-child(4) { grid-column: 3/4; grid-row: 2/3; --r: -.6deg; }
  .frame:nth-child(5) { grid-column: 1/2; grid-row: 3/5; --r: 1.2deg; }
  .frame:nth-child(6) { grid-column: 2/4; grid-row: 3/4; --r: -.8deg; }
  .frame:nth-child(7) { grid-column: 2/3; grid-row: 4/5; --r: 1.6deg; }
  .frame:nth-child(8) { grid-column: 3/5; grid-row: 4/5; --r: -1deg; }
  .note { grid-column: 4/5; grid-row: 3/4; --r: 2deg; }

  /* handwritten pinned note */
  .note {
    background: transparent; padding: .8rem; margin: 0;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-hand); font-style: italic;
    font-size: 1.2rem; line-height: 1.35; text-align: center;
    white-space: pre-line; color: var(--fg);
    transform: rotate(var(--r, 0deg));
  }
  .note--accent { color: var(--accent); }

  /* dramatic cascading reveal on scroll (rise + scale + blur, spring).
     IMPORTANT: the polaroid rotation (var(--r)) is preserved in every state;
     hidden state ONLY under .wf-js (anti-flash, never at rest). */
  :global(.wf-js) .frame.wf-rev,
  :global(.wf-js) .note.wf-rev {
    opacity: 0;
    transform: rotate(var(--r, 0deg)) translateY(42px) scale(.92);
    filter: blur(6px);
    transition: opacity .8s var(--ease), transform .9s var(--easeBack),
      filter .8s var(--ease), box-shadow .35s var(--ease);
    transition-delay: var(--d, 0s);
  }
  :global(.wf-js) .frame.wf-rev.is-in,
  :global(.wf-js) .note.wf-rev.is-in {
    opacity: 1;
    transform: rotate(var(--r, 0deg)); filter: none;
  }
  /* EXIT variant B — mirror of the entry, upwards (inverted Y, same scale/blur) */
  :global(.wf-js) .frame.wf-rev.wf-exit-up,
  :global(.wf-js) .note.wf-rev.wf-exit-up {
    opacity: 0;
    transform: rotate(var(--r, 0deg)) translateY(-42px) scale(.92);
    filter: blur(6px);
  }
  /* once revealed, hand back to the (fast) hover transition */
  :global(.wf-js) .frame.wf-rev.is-in { transition: transform .35s var(--ease), box-shadow .35s var(--ease); }
  /* cascading delays per index (DOM order) */
  :global(.wf-js) .grid > :nth-child(1) { --d: .04s; }
  :global(.wf-js) .grid > :nth-child(2) { --d: .10s; }
  :global(.wf-js) .grid > :nth-child(3) { --d: .16s; }
  :global(.wf-js) .grid > :nth-child(4) { --d: .22s; }
  :global(.wf-js) .grid > :nth-child(5) { --d: .28s; }
  :global(.wf-js) .grid > :nth-child(6) { --d: .34s; }
  :global(.wf-js) .grid > :nth-child(7) { --d: .40s; }
  :global(.wf-js) .grid > :nth-child(8) { --d: .46s; }
  :global(.wf-js) .grid > :nth-child(9) { --d: .52s; }

  @media (max-width: 780px) {
    .grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: minmax(8rem, auto); }
    .frame:nth-child(n) { grid-column: auto; grid-row: auto; }
    .frame { aspect-ratio: 4/5; }
    .note { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    * { transition: none !important; }
    :global(.wf-js) .frame.wf-rev,
    :global(.wf-js) .note.wf-rev {
      opacity: 1 !important;
      transform: rotate(var(--r, 0deg)) !important; filter: none !important;
    }
  }
</style>

<script>
  document.documentElement.classList.add("wf-js");
  document.querySelectorAll<HTMLElement>(".ti-polaroids").forEach((section) => {
    const els = Array.from(section.querySelectorAll(".wf-rev"));
    if (!els.length) return;
    const reduce = window.matchMedia("(prefers-reduced-motion:reduce)").matches;
    if (reduce || !("IntersectionObserver" in window)) {
      els.forEach((el) => el.classList.add("is-in"));
      return;
    }
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add("is-in");
          e.target.classList.remove("wf-exit-up");
        } else {
          e.target.classList.remove("is-in");
          e.target.classList.toggle("wf-exit-up", e.boundingClientRect.top < 0);
        }
      });
    }, { threshold: 0.12 });
    els.forEach((el) => io.observe(el));
  });
</script>
