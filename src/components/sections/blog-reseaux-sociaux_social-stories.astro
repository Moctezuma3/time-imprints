---
/**
 * Integration — section `blog-reseaux-sociaux_social-stories` (normal section, not bleed).
 * Phase 2 rules applied:
 *   1. Local :root tokens, reset, Google-Fonts markup removed → inherited from base.
 *   2. No min-height / no internal vertical padding → base `--section-y` rhythm.
 *   3. Instagram-orange ring gradient → brand conic gradient --accent→--accent-2;
 *      all rgba()/#hex → theme tokens + color-mix() tints, shadows on --shadow-color.
 *   4. Eyebrow removed (typographic sobriety rule). "Add story" bubble removed
 *      (owner-only UI). Story circles + reel cards became real links:
 *      stories → Instagram profile, reels → TikTok (external, noopener).
 *   5. View counters dropped (no invented numbers) — captions only; the real
 *      197K TikTok likes figure lives in the handle chip.
 *   6. Drag-to-scroll JS scoped to `.ti-stories .reels` (safe for 0 or n
 *      occurrences); click-after-drag suppressed because tiles are links.
 *      No reveal pattern: the library original has none.
 */
import { SITE } from "../../data/site";

export interface Props {
  title?: string;
  intro?: string;
  stories?: { label: string; image: string }[];
  reels?: { image: string; caption: string }[];
}
const {
  title = "As seen on TikTok",
  intro = "Stories, reels and happy accidents — how the kits look in real hands, filmed as it happens.",
  stories = [
    { label: "Body", image: "/img/kit-body.jpg" },
    { label: "Hugs", image: "/img/kit-hugs.jpg" },
    { label: "Kisses", image: "/img/kit-kisses.jpg" },
    { label: "Hands", image: "/img/kit-hands.jpg" },
    { label: "Reviews", image: "/img/family.jpg" },
  ],
  reels = [
    { image: "/img/hero-1.jpg", caption: "The family canvas reveal" },
    { image: "/img/hero-3.jpg", caption: "A hug you can wear" },
    { image: "/img/kit-body-2.jpg", caption: "Body Imprints — how it's made" },
    { image: "/img/kit-hugs-2.jpg", caption: "Painting each other's arms" },
    { image: "/img/gallery-05.jpg", caption: "Date night, but messier" },
    { image: "/img/gallery-07.jpg", caption: "When the paint finally dries" },
  ],
} = Astro.props;
---

<section class="ti-stories" aria-label="Stories and reels">
  <div class="st__inner">
    <div class="st__head">
      <div>
        <h2 class="st__title" data-slot="titre">{title}</h2>
        <p class="st__intro">{intro}</p>
      </div>
      <a class="st__handle" href={SITE.tiktok} target="_blank" rel="noopener" aria-label={`${SITE.handle} on TikTok — ${SITE.tiktokLikes} likes`} data-slot="compte">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
        {SITE.handle} · {SITE.tiktokLikes} ❤
      </a>
    </div>

    <!-- Stories -->
    <div class="stories" aria-label="Story highlights">
      {stories.map((s) => (
        <a class="story" href={SITE.instagram} target="_blank" rel="noopener" aria-label={`${s.label} — story highlights on Instagram`}>
          <span class="story__ring"><img class="story__av" src={s.image} alt="" loading="lazy" /></span>
          <span class="story__label">{s.label}</span>
        </a>
      ))}
    </div>

    <!-- Reels -->
    <div class="reels" aria-label="Latest reels (drag to scroll)" data-slot="posts">
      {reels.map((r) => (
        <a class="reel" href={SITE.tiktok} target="_blank" rel="noopener" aria-label={`Watch “${r.caption}” on TikTok`} data-slot-item>
          <img data-field="image" src={r.image} alt={r.caption} loading="lazy" draggable="false" />
          <span class="reel__play" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          </span>
          <span class="reel__cap" data-field="titre">{r.caption}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .ti-stories {
    --ease: cubic-bezier(.16,1,.3,1);
    --ring: conic-gradient(from 210deg, var(--accent), var(--accent-2), var(--accent));
    color: var(--fg);
  }
  .st__inner { width: 100%; max-width: var(--container); margin-inline: auto; padding-inline: var(--gutter); }

  /* head ------------------------------------------------------------------ */
  .st__head { display: flex; flex-wrap: wrap; align-items: flex-end; justify-content: space-between; gap: 1rem; margin-bottom: 2rem; }
  .st__title { font-size: clamp(1.9rem, 3.8vw, 2.8rem); font-weight: 800; letter-spacing: -.025em; line-height: 1.1; }
  .st__intro { color: var(--muted); margin-top: .5rem; max-width: 46ch; }
  .st__handle {
    display: inline-flex; align-items: center; gap: .5rem; font-weight: 600; font-size: .95rem;
    border: 1px solid var(--line); background: var(--surface); border-radius: 2rem; padding: .55rem 1.1rem;
    text-decoration: none; white-space: nowrap;
    transition: border-color .2s, transform .2s var(--ease);
  }
  .st__handle svg { width: 1.05rem; height: 1.05rem; color: var(--accent-2); }

  /* stories rail ------------------------------------------------------------ */
  .stories { display: flex; gap: 1.1rem; overflow-x: auto; padding: .4rem .1rem 1.4rem; scrollbar-width: none; }
  .stories::-webkit-scrollbar { display: none; }
  .story { flex: 0 0 auto; display: flex; flex-direction: column; align-items: center; gap: .5rem; width: 4.6rem; text-decoration: none; }
  .story__ring {
    display: block; width: 4.4rem; height: 4.4rem; border-radius: 50%; padding: 3px;
    background: var(--ring); transition: transform .2s var(--ease);
  }
  .story__av { width: 100%; height: 100%; border-radius: 50%; border: 3px solid var(--bg); object-fit: cover; background: var(--surface); }
  .story__label { font-size: .74rem; color: var(--muted); max-width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  /* reels carousel ----------------------------------------------------------- */
  .reels {
    display: flex; gap: 1rem; overflow-x: auto; padding: .3rem .1rem 1rem;
    scroll-snap-type: x mandatory; scrollbar-width: none; cursor: grab; user-select: none;
  }
  .reels::-webkit-scrollbar { display: none; }
  .reels.grabbing { cursor: grabbing; }
  .reel {
    flex: 0 0 auto; width: 13.5rem; aspect-ratio: 9 / 16; border-radius: var(--radius);
    overflow: hidden; position: relative; scroll-snap-align: start; display: block;
    background: var(--surface); box-shadow: 0 14px 30px -22px var(--shadow-color);
    text-decoration: none;
  }
  .reel img { width: 100%; height: 100%; object-fit: cover; opacity: .92; }
  /* scrim for caption legibility */
  .reel::after {
    content: ""; position: absolute; inset: 0;
    background: linear-gradient(180deg,
      color-mix(in srgb, var(--bg) 5%, transparent),
      color-mix(in srgb, var(--bg) 72%, transparent));
  }
  .reel__play {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 2;
    width: 3rem; height: 3rem; border-radius: 50%;
    background: color-mix(in srgb, var(--accent-contrast) 92%, transparent);
    display: grid; place-items: center; transition: transform .2s var(--ease);
  }
  .reel__play svg { width: 1.2rem; height: 1.2rem; fill: var(--bg); margin-left: 2px; }
  .reel__cap {
    position: absolute; left: 0; right: 0; bottom: 0; z-index: 2; padding: .9rem;
    color: var(--accent-contrast); font-weight: 600; font-size: .92rem; line-height: 1.35;
  }

  /* hover -------------------------------------------------------------------- */
  @media (hover: hover) and (pointer: fine) {
    .story:hover .story__ring { transform: scale(1.05); }
    .reel:hover .reel__play { transform: translate(-50%, -50%) scale(1.08); }
    .st__handle:hover { border-color: color-mix(in srgb, var(--fg) 25%, var(--line)); transform: translateY(-1px); }
  }

  /* responsive + accessibility ------------------------------------------------ */
  @media (max-width: 560px) {
    .reel { width: 11rem; }
    .story { width: 4.1rem; }
    .story__ring { width: 3.9rem; height: 3.9rem; }
  }
  @media (max-width: 640px) {
    .st__head { justify-content: center; text-align: center; }
    .st__intro { margin-inline: auto; }
  }
  @media (prefers-reduced-motion: reduce) {
    * { transition: none !important; }
    .reels { scroll-behavior: auto; }
  }
</style>

<script>
  /* Drag-to-scroll on the reels carousel (touch/keyboard handled natively by
     overflow + scroll-snap). Scoped to this section; safe for 0 or n instances. */
  (function () {
    document.querySelectorAll<HTMLElement>(".ti-stories .reels").forEach((el) => {
      let down = false, startX = 0, startScroll = 0, moved = 0;
      el.addEventListener("pointerdown", (e) => {
        down = true; moved = 0; startX = e.clientX; startScroll = el.scrollLeft;
        el.classList.add("grabbing");
        try { el.setPointerCapture(e.pointerId); } catch (_) { /* noop */ }
      });
      el.addEventListener("pointermove", (e) => {
        if (!down) return;
        const dx = e.clientX - startX;
        moved = Math.max(moved, Math.abs(dx));
        el.scrollLeft = startScroll - dx;
      });
      const end = () => { down = false; el.classList.remove("grabbing"); };
      el.addEventListener("pointerup", end);
      el.addEventListener("pointercancel", end);
      /* the tiles are links: swallow the accidental click that follows a drag */
      el.addEventListener("click", (e) => {
        if (moved > 6) { e.preventDefault(); e.stopPropagation(); }
      }, true);
    });
  })();
</script>
