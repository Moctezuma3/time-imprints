---
/**
 * Intégration — section `pieds-de-page_footer-rich` (placement: footer).
 * Placée dans le slot "footer" du Layout. Règles Phase 2 :
 *   :root + reset supprimés → tokens hérités ; `--primary` → `--accent` ;
 *   logo placehold.co retiré → wordmark texte (asset client [À FOURNIR]) ;
 *   max-width → --container ; JS natif (reveal cascade) préservé.
 */
export interface Props {
  brand?: string;
  desc?: string;
  columns?: { titre: string; items: { label: string; href: string }[] }[];
  mentions?: string;
  legal?: { label: string; href: string }[];
  social?: { instagram?: string; facebook?: string; twitter?: string; linkedin?: string };
}
const {
  brand = "MarqueSite",
  desc = "Brève description de l'activité en une phrase, pour présenter ce que vous faites et à qui vous vous adressez.",
  columns = [
    { titre: "Véhicules", items: [
      { label: "Citadine", href: "/vehicules/citadines" },
      { label: "Utilitaire", href: "/vehicules/utilitaire" },
      { label: "Minibus 7 places", href: "/vehicules/familiales" },
    ]},
    { titre: "Entreprise", items: [
      { label: "À propos", href: "/a-propos" },
      { label: "Professionnels", href: "/professionnels" },
      { label: "Blog", href: "/blog" },
    ]},
    { titre: "Aide", items: [
      { label: "Contact", href: "/contact" },
      { label: "Emplacements", href: "/emplacements" },
    ]},
  ],
  mentions = "© 2026 MarqueSite. Tous droits réservés.",
  legal = [
    { label: "Conditions générales", href: "#" },
    { label: "Politique de confidentialité", href: "#" },
  ],
  social = {},
} = Astro.props;
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__top">
      <div class="footer__brand wf-rev">
        <a href="/" class="footer__logo" aria-label="Accueil">
          <h2 data-slot="logo">{brand}</h2>
        </a>
        <p class="footer__desc">{desc}</p>
        <ul class="footer__social" aria-label="Réseaux sociaux" data-slot="social">
          <li data-slot-item><a href={social.instagram ?? "#"} aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a></li>
          <li><a href={social.facebook ?? "#"} aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.5-3.89 3.78-3.89 1.1 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.45 2.89h-2.33v6.99A10 10 0 0 0 22 12z"/></svg>
          </a></li>
          <li><a href={social.twitter ?? "#"} aria-label="Twitter">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a></li>
          <li><a href={social.linkedin ?? "#"} aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/></svg>
          </a></li>
        </ul>
      </div>

      <div class="footer__cols">
        {columns.map((col, i) => (
          <div class="footer__col wf-rev" style={`--d:${0.08 + i * 0.08}s`} data-slot="liens">
            <h3>{col.titre}</h3>
            <ul>
              {col.items.map((it) => <li data-slot-item><a href={it.href}>{it.label}</a></li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="footer__bottom wf-rev" style="--d:.3s">
      <p class="footer__copy" data-slot="mentions">{mentions}</p>
      <ul class="footer__legal">
        {legal.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </div>
  </div>
</footer>

<style>
  .footer {
    --ease: cubic-bezier(.16, 1, .3, 1); --easeBack: cubic-bezier(.34, 1.56, .64, 1);
    background: var(--surface); color: var(--fg);
    border-top: 1px solid var(--line);
    padding: clamp(3rem, 8vh, 5rem) var(--gutter) 0;
  }
  .footer a { text-decoration: none; color: inherit; }
  .footer ul { list-style: none; margin: 0; padding: 0; }
  .footer__inner { max-width: var(--container); margin: 0 auto; }

  .wf-js .wf-rev { opacity: 0; transform: translateY(24px); transition: opacity .7s var(--ease), transform .8s var(--easeBack); transition-delay: var(--d, 0s); }
  .wf-js .wf-rev.is-in { opacity: 1; transform: none; }

  .footer__col a, .footer__legal a { position: relative; }
  .footer__col a::after, .footer__legal a::after { content: ""; position: absolute; left: 0; right: 100%; bottom: -2px; height: 1px; background: currentColor; transition: right .3s var(--ease); }
  @media (hover: hover) and (pointer: fine) { .footer__col a:hover::after, .footer__legal a:hover::after { right: 0; } }

  .footer__top { display: flex; flex-direction: column; gap: 2.5rem; justify-content: space-between; }
  @media (min-width: 960px) { .footer__top { flex-direction: row; align-items: flex-start; gap: 4rem; } }

  .footer__brand { display: flex; flex-direction: column; gap: 1.5rem; width: 100%; max-width: 24rem; }
  .footer__logo h2 { font-size: 1.25rem; font-weight: 700; letter-spacing: -.01em; }
  .footer__desc { font-size: .92rem; color: var(--muted); line-height: 1.6; }
  .footer__social { display: flex; align-items: center; gap: 1.4rem; }
  .footer__social a { color: var(--muted); display: inline-flex; transition: color .2s, transform .2s var(--ease); }
  .footer__social svg { width: 1.15rem; height: 1.15rem; }
  @media (hover: hover) and (pointer: fine) { .footer__social a:hover { color: var(--accent); transform: translateY(-2px); } }

  .footer__cols { display: grid; gap: 1.8rem; width: 100%; grid-template-columns: repeat(2, minmax(0, 1fr)); }
  @media (min-width: 600px) { .footer__cols { grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 2.5rem; } }
  @media (min-width: 960px) { .footer__cols { gap: 4rem; } }
  .footer__col h3 { font-size: .95rem; font-weight: 700; margin-bottom: 1rem; }
  .footer__col li { margin-bottom: .65rem; }
  .footer__col a { font-size: .9rem; font-weight: 500; color: var(--muted); transition: color .2s; }
  @media (hover: hover) and (pointer: fine) { .footer__col a:hover { color: var(--accent); } }

  .footer__bottom { margin-top: 2.5rem; border-top: 1px solid var(--line); padding: 1.8rem 0; display: flex; flex-direction: column; gap: .8rem; font-size: .78rem; font-weight: 500; color: var(--muted); }
  .footer__legal { display: flex; flex-direction: column; gap: .5rem; }
  .footer__legal a { transition: color .2s; }
  @media (hover: hover) and (pointer: fine) { .footer__legal a:hover { color: var(--accent); } }
  @media (min-width: 680px) {
    .footer__bottom { flex-direction: row; align-items: center; justify-content: space-between; }
    .footer__legal { flex-direction: row; gap: 1.4rem; order: 2; }
    .footer__copy { order: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer__social a { transition: none; }
    .wf-js .wf-rev { opacity: 1 !important; transform: none !important; transition: none; }
    .footer__col a::after, .footer__legal a::after { transition: none; }
  }
</style>

<script>
  document.documentElement.classList.add("wf-js");
  (function () {
    const els = [].slice.call(document.querySelectorAll(".footer .wf-rev")) as Element[];
    if (!els.length) return;
    if (!("IntersectionObserver" in window) || window.matchMedia("(prefers-reduced-motion:reduce)").matches) {
      els.forEach((el) => el.classList.add("is-in"));
      return;
    }
    const io = new IntersectionObserver((entries, obs) => {
      entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add("is-in"); obs.unobserve(e.target); } });
    }, { threshold: 0.15 });
    els.forEach((el) => io.observe(el));
  })();
</script>
