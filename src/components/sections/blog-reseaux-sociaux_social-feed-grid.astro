---
/**
 * Integration — section `blog-reseaux-sociaux_social-feed-grid` (normal section, not bleed).
 * Phase 2 rules applied:
 *   1. Local :root tokens, reset, Google-Fonts markup removed → inherited from base.
 *   2. No min-height / no internal vertical padding → base `--section-y` rhythm.
 *   3. Hard-coded colors (Instagram gradient, blue accent, rgba overlays) → theme
 *      tokens: brand gradient --accent→--accent-2, color-mix() tints, --shadow-color.
 *   4. Account header wired to real Time Imprints data (logo avatar, @time_imprints,
 *      58K followers); Follow + TikTok buttons reuse the global .btn classes.
 *   5. 6 real feed covers with real like counts; every tile opens Instagram.
 *   6. JS scoped to `.ti-feedgrid` instances (safe for 0 or n occurrences).
 *      NOTE: `.wf-js` lives on <html>, outside this component → written as
 *      `:global(.wf-js)` so the selector survives Astro's attribute scoping.
 */
import { SITE } from "../../data/site";

export interface Props {
  title?: string;
  posts?: { image: string; likes: string; alt?: string }[];
}
const {
  title = "Join 58,000 people who watch us make a mess",
  posts = [
    { image: "/img/feed-1.jpg", likes: "985K", alt: "Time Imprints reel cover — our most-liked video, 985K likes" },
    { image: "/img/feed-2.jpg", likes: "694K", alt: "Time Imprints reel cover — 694K likes" },
    { image: "/img/feed-3.jpg", likes: "164K", alt: "Time Imprints reel cover — 164K likes" },
    { image: "/img/feed-4.jpg", likes: "138K", alt: "Time Imprints reel cover — 138K likes" },
    { image: "/img/feed-5.jpg", likes: "93K", alt: "Time Imprints reel cover — 93K likes" },
    { image: "/img/feed-6.jpg", likes: "69K", alt: "Time Imprints reel cover — 69K likes" },
  ],
} = Astro.props;
---

<section class="ti-feedgrid" aria-label="Our Instagram feed">
  <div class="fg__inner">
    <h2 class="fg__title" data-slot="titre">{title}</h2>

    <header class="account">
      <span class="account__avatar">
        <img src="/img/logo.jpg" alt="Time Imprints logo" loading="lazy" width="120" height="120" />
      </span>
      <div class="account__meta">
        <p class="account__handle" data-slot="compte">
          {SITE.handle}
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5zm5 5a5 5 0 1 0 0 10 5 5 0 0 0 0-10zm0 2a3 3 0 1 1 0 6 3 3 0 0 1 0-6zm5.5-3a1 1 0 1 0 0 2 1 1 0 0 0 0-2z"/></svg>
        </p>
        <p class="account__stats"><b>{SITE.followers}</b> followers</p>
      </div>
      <div class="account__actions">
        <a class="btn btn--primary" href={SITE.instagram} target="_blank" rel="noopener">Follow</a>
        <a class="btn btn--ghost" href={SITE.tiktok} target="_blank" rel="noopener">TikTok · {SITE.tiktokLikes} ❤</a>
      </div>
    </header>

    <div class="feed" data-slot="posts">
      {posts.map((p) => (
        <a
          class="post wf-rev"
          href={SITE.instagram}
          target="_blank"
          rel="noopener"
          aria-label={`${p.likes} likes — open our Instagram`}
          data-slot-item
        >
          <span class="post__spot" aria-hidden="true"></span>
          <span class="post__type" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          </span>
          <img data-field="image" src={p.image} alt={p.alt ?? ""} loading="lazy" />
          <span class="post__overlay" aria-hidden="true">
            <span>
              <svg viewBox="0 0 24 24"><path d="M12 21s-7-4.6-9.5-9C1 9 2.5 5.5 6 5.5c2 0 3.2 1.2 4 2.2.8-1 2-2.2 4-2.2 3.5 0 5 3.5 3.5 6.5C19 16.4 12 21 12 21z"/></svg>
              {p.likes}
            </span>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .ti-feedgrid { --ease: cubic-bezier(.16,1,.3,1); --easeBack: cubic-bezier(.34,1.56,.64,1); color: var(--fg); }
  .fg__inner { width: 100%; max-width: min(64rem, var(--container)); margin-inline: auto; padding-inline: var(--gutter); }

  .fg__title {
    font-size: clamp(2rem, 4.4vw, 3rem); font-weight: 800; line-height: 1.08;
    letter-spacing: -.02em; max-width: 24ch; margin-bottom: clamp(1.6rem, 4vw, 2.4rem);
  }

  /* account header ------------------------------------------------------- */
  .account { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.6rem; flex-wrap: wrap; }
  .account__avatar {
    width: 3.6rem; height: 3.6rem; border-radius: 50%; flex: none; display: block;
    background: linear-gradient(135deg, var(--accent), var(--accent-2)); padding: 2px;
  }
  .account__avatar img { width: 100%; height: 100%; border-radius: 50%; object-fit: cover; border: 2px solid var(--bg); }
  .account__meta { flex: 1; min-width: 0; }
  .account__handle { font-weight: 700; display: flex; align-items: center; gap: .4rem; }
  .account__handle svg { width: 1.1rem; height: 1.1rem; fill: var(--accent); }
  .account__stats { font-size: .88rem; color: var(--muted); }
  .account__stats b { color: var(--fg); }
  .account__actions { display: flex; gap: .6rem; flex-wrap: wrap; }
  .account__actions :global(.btn) { font-size: .9rem; white-space: nowrap; }

  /* posts grid ------------------------------------------------------------ */
  .feed { display: grid; grid-template-columns: repeat(3, 1fr); gap: .55rem; }
  .post {
    position: relative; aspect-ratio: 1; border-radius: calc(var(--radius) - 6px);
    overflow: hidden; background: var(--surface); display: block;
  }
  .post img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s var(--ease); }
  /* light spot following the cursor (under the overlay and the badges) */
  .post__spot {
    position: absolute; inset: 0; pointer-events: none; z-index: 1; opacity: 0;
    transition: opacity .3s var(--ease);
    background: radial-gradient(220px circle at var(--mx, 50%) var(--my, 50%),
      color-mix(in srgb, var(--accent-contrast) 32%, transparent), transparent 60%);
    mix-blend-mode: overlay;
  }
  .post__type {
    position: absolute; top: .55rem; right: .55rem; z-index: 3;
    color: var(--accent-contrast); filter: drop-shadow(0 1px 2px var(--shadow-color));
  }
  .post__type svg { width: 1.1rem; height: 1.1rem; fill: currentColor; }
  .post__overlay {
    position: absolute; inset: 0; z-index: 2; display: flex; align-items: center; justify-content: center; gap: 1.1rem;
    background: color-mix(in srgb, var(--bg) 62%, transparent);
    color: var(--accent-contrast); font-weight: 700; opacity: 0; transition: opacity .25s;
  }
  .post__overlay span { display: inline-flex; align-items: center; gap: .35rem; }
  .post__overlay svg { width: 1.1rem; height: 1.1rem; fill: var(--accent); }
  .post:focus-visible .post__overlay { opacity: 1; }

  @media (hover: hover) and (pointer: fine) {
    .post:hover img { transform: scale(1.06); }
    .post:hover .post__overlay { opacity: 1; }
    .post:hover .post__spot { opacity: 1; }
  }

  /* reveal cascade on scroll (hidden state ONLY under .wf-js — anti-flash) */
  :global(.wf-js) .post.wf-rev {
    opacity: 0; transform: translateY(28px) scale(.96); filter: blur(4px);
    transition: opacity .7s var(--ease), transform .8s var(--easeBack), filter .7s var(--ease);
    transition-delay: var(--d, 0s);
  }
  :global(.wf-js) .post.wf-rev.is-in { opacity: 1; transform: none; filter: none; }
  :global(.wf-js) .feed .post:nth-child(1)  { --d: .04s; }
  :global(.wf-js) .feed .post:nth-child(2)  { --d: .09s; }
  :global(.wf-js) .feed .post:nth-child(3)  { --d: .14s; }
  :global(.wf-js) .feed .post:nth-child(4)  { --d: .19s; }
  :global(.wf-js) .feed .post:nth-child(5)  { --d: .24s; }
  :global(.wf-js) .feed .post:nth-child(6)  { --d: .29s; }
  :global(.wf-js) .feed .post:nth-child(7)  { --d: .34s; }
  :global(.wf-js) .feed .post:nth-child(8)  { --d: .39s; }
  :global(.wf-js) .feed .post:nth-child(9)  { --d: .44s; }
  :global(.wf-js) .feed .post:nth-child(10) { --d: .49s; }
  :global(.wf-js) .feed .post:nth-child(11) { --d: .54s; }
  :global(.wf-js) .feed .post:nth-child(12) { --d: .59s; }

  /* responsive ------------------------------------------------------------- */
  @media (max-width: 640px) {
    .feed { grid-template-columns: repeat(2, 1fr); }
    .account { justify-content: center; text-align: center; }
    .account__handle { justify-content: center; }
    .account__actions { justify-content: center; }
    .fg__title { margin-inline: auto; }
  }

  @media (prefers-reduced-motion: reduce) {
    * { transition: none !important; }
    :global(.wf-js) .post.wf-rev { opacity: 1 !important; transform: none !important; filter: none !important; }
  }
</style>

<script>
  document.documentElement.classList.add("wf-js");
  (function () {
    const reduce = window.matchMedia("(prefers-reduced-motion:reduce)").matches;
    const fine = window.matchMedia("(hover:hover) and (pointer:fine)").matches;

    document.querySelectorAll<HTMLElement>(".ti-feedgrid").forEach((section) => {
      /* reveal cascade on scroll */
      const revs = Array.from(section.querySelectorAll(".wf-rev"));
      if (reduce || !("IntersectionObserver" in window)) {
        revs.forEach((el) => el.classList.add("is-in"));
      } else {
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((e) => {
              if (e.isIntersecting) { e.target.classList.add("is-in"); obs.unobserve(e.target); }
            });
          },
          { threshold: 0.15 }
        );
        revs.forEach((el) => io.observe(el));
      }

      /* light spot following the cursor on each tile */
      if (reduce || !fine) return;
      section.querySelectorAll<HTMLElement>(".post").forEach((post) => {
        post.addEventListener("mousemove", (e) => {
          const r = post.getBoundingClientRect();
          post.style.setProperty("--mx", (((e.clientX - r.left) / r.width) * 100).toFixed(1) + "%");
          post.style.setProperty("--my", (((e.clientY - r.top) / r.height) * 100).toFixed(1) + "%");
        });
      });
    });
  })();
</script>
